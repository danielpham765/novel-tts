{
  "source_id": "1qxs",
  "resolver_id": "1qxs",
  "crawl": {
    "site_id": "1qxs",
    "chapter_batch_size": 10,
    "chapter_regex": "^第(\\d+)章([^\\n]*)",
    "preferred_fetch_mode": "auto",
    "request_timeout_seconds": 120,
    "content_wait_timeout_seconds": 45,
    "delay_between_chapters_seconds": 0.4,
    "max_fetch_retries": 3,
    "retry_backoff_seconds": 12.0,
    "rate_limit_cooldown_seconds": 60.0
  },
  "browser_debug": {
    "mode": "auto",
    "remote_debugging_url": "",
    "remote_debugging_port": 9222,
    "executable_path": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "user_data_dir": "",
    "profile_directory": "",
    "headless": false,
    "debug_image_dir": "debug/img"
  }
}

